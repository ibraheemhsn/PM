# انسخ هذا الملف إلى .env وعدّل القيم — يقرأه docker compose تلقائياً

# النطاق الذي يشير إلى عنوان الخادم (لإصدار HTTPS تلقائياً)
SITE_DOMAIN=pm.example.com
SITE_ADDRESS=pm.example.com
# للتجربة على جهازك بلا نطاق استخدم:
#   SITE_DOMAIN=localhost
#   SITE_ADDRESS=:80

# ولّد مفتاحاً عشوائياً طويلاً (60+ حرفاً)
DJANGO_SECRET_KEY=CHANGE-ME-to-a-long-random-string

POSTGRES_DB=pm
POSTGRES_USER=pmuser
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password

# انسخ هذا الملف إلى .env وعدّل القيم — يقرأه docker compose تلقائياً

# النطاق الذي يشير إلى عنوان الخادم (لإصدار HTTPS تلقائياً)
SITE_DOMAIN=pm.example.com
SITE_ADDRESS=pm.example.com
# للتجربة على جهازك بلا نطاق استخدم:
#   SITE_DOMAIN=localhost
#   SITE_ADDRESS=:80

# ولّد مفتاحاً عشوائياً طويلاً (60+ حرفاً)
DJANGO_SECRET_KEY=CHANGE-ME-to-a-long-random-string

POSTGRES_DB=pm
POSTGRES_USER=pmuser
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password

# مفاتيح إشعارات Web Push (VAPID) — ولّدها على الخادم بالأمر الموثق في
# deploy/README.md ثم الصقها هنا (تُترك فارغة فتعمل بمفاتيح التطوير)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=baitydev3@gmail.com

# انسخ هذا الملف إلى /srv/pm/server/.env وعدّل القيم
# ولّد مفتاحاً سرياً بـ:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=CHANGE-ME-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=pm.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://pm.example.com

POSTGRES_DB=pm
POSTGRES_USER=pmuser
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# «تسجيل الدخول عبر Google» لربط البريد (اختياري) — أنشئ بيانات عميل OAuth
# من console.cloud.google.com وسجّل نفس عنوان العودة في شاشة الاعتماد
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://pm.example.com/api/email/oauth/callback/
